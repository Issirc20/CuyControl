@model CuyControl.Web.ViewModels.MovimientoAlimentoViewModel
@using CuyControl.Domain.Enums

@{
    ViewData["Title"] = "Nuevo Movimiento de Alimento";
}

<h2>Registrar Movimiento de Alimento</h2>

<form asp-action="Create" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="mb-3">
        <label class="form-label">Alimento</label>
        <select asp-for="InventarioAlimentoId" asp-items="ViewBag.Inventarios" class="form-select">
            <option value="">Seleccione</option>
        </select>
        <span asp-validation-for="InventarioAlimentoId" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Tipo de Movimiento</label>
        <select asp-for="TipoMovimiento" class="form-select">
            <option value="@TipoMovimientoAlimentoEnum.Entrada">Entrada</option>
            <option value="@TipoMovimientoAlimentoEnum.Salida">Salida</option>
        </select>
        <span asp-validation-for="TipoMovimiento" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Cantidad</label>
        <input asp-for="Cantidad" type="number" step="0.01" class="form-control" />
        <span asp-validation-for="Cantidad" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha</label>
        <input asp-for="FechaMovimiento" type="date" class="form-control" />
        <span asp-validation-for="FechaMovimiento" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Observaciones</label>
        <textarea asp-for="Observaciones" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">
        Guardar
    </button>

    <a asp-action="Index" class="btn btn-secondary">
        Cancelar
    </a>
</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}