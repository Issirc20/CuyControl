@model LoginViewModel

@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CuyControl</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        html, body {
            height: 100%;
        }

        body {
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        .login-container {
            background: white;
            border-radius: 10px;
            box-shadow: 0 10px 25px rgba(0, 0, 0, 0.2);
            padding: 40px;
            width: 100%;
            max-width: 400px;
        }

        .login-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .login-header h1 {
            color: #667eea;
            font-weight: bold;
        }

        .btn-login {
            width: 100%;
            padding: 10px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border: none;
        }

        .btn-login:hover {
            background: linear-gradient(135deg, #5a6fd8 0%, #6a4196 100%);
        }
    </style>
</head>
<body>
    <div class="login-container">
        <div class="login-header">
            <h1>CuyControl</h1>
            <p class="text-muted">Sistema de Gestión de Cuyes</p>
        </div>

        @if (!string.IsNullOrEmpty(Model?.ErrorMessage))
        {
            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                @Model.ErrorMessage
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <form method="post" asp-action="Login">
            <input type="hidden" asp-for="ReturnUrl" />
            <div class="mb-3">
                <label asp-for="NombreUsuario" class="form-label">Usuario</label>
                <input asp-for="NombreUsuario" class="form-control" placeholder="Ingrese su usuario" />
                <span asp-validation-for="NombreUsuario" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Contrasena" class="form-label">Contraseña</label>
                <input asp-for="Contrasena" class="form-control" type="password" placeholder="Ingrese su contraseña" />
                <span asp-validation-for="Contrasena" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="RecordarMe" type="checkbox" class="form-check-input" />
                <label asp-for="RecordarMe" class="form-check-label">Recuérdame</label>
            </div>

            <button type="submit" class="btn btn-primary btn-login">Iniciar Sesión</button>
        </form>

        <hr />
        <div class="text-center text-muted small">
            <p>Usuario: admin | Contraseña: Admin@123456</p>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
</body>
</html>
