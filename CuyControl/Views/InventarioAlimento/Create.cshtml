@model CuyControl.Web.ViewModels.InventarioAlimentoViewModel

<h2>Registrar Alimento</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label">Tipo de alimento</label>
        <input asp-for="TipoAlimento" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Cantidad actual</label>
        <input asp-for="CantidadActual" type="number" step="0.01" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Cantidad mínima</label>
        <input asp-for="CantidadMinima" type="number" step="0.01" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Costo unitario</label>
        <input asp-for="CostoUnitario" type="number" step="0.01" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Observaciones</label>
        <textarea asp-for="Observaciones" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Guardar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>