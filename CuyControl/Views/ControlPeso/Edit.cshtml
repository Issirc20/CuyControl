@model CuyControl.Web.ViewModels.ControlPesoViewModel

<h2>Editar Control de Peso</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Cuy</label>
        <select asp-for="CuyId" asp-items="ViewBag.Cuyes" class="form-select">
            <option value="">Seleccione</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Peso en gramos</label>
        <input asp-for="Peso" type="number" step="0.01" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha de pesaje</label>
        <input asp-for="FechaPesaje" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Observaciones</label>
        <textarea asp-for="Observaciones" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>