@model IEnumerable<CuyControl.Web.ViewModels.ControlPesoViewModel>

@{
    ViewData["Title"] = "Control de Peso";
}

<h2>Control de Peso</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    Nuevo Control
</a>

<table class="table table-bordered table-striped">

    <thead>
        <tr>
            <th>Cuy</th>
            <th>Peso</th>
            <th>Fecha</th>
            <th>Observaciones</th>
            <th>Acciones</th>
        </tr>
    </thead>

    <tbody>

        @foreach (var item in Model)
        {
            <tr>

                <td>@item.CuyCodigo</td>

                <td>@item.Peso g</td>

                <td>@item.FechaPesaje.ToShortDateString()</td>

                <td>@item.Observaciones</td>

                <td>

                    <a asp-action="Details"
                       asp-route-id="@item.Id"
                       class="btn btn-info btn-sm">
                        Ver
                    </a>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id"
                       class="btn btn-warning btn-sm">
                        Editar
                    </a>

                    <form asp-action="Delete"
                          asp-route-id="@item.Id"
                          method="post"
                          style="display:inline;">

                        <button type="submit"
                                class="btn btn-danger btn-sm"
                                onclick="return confirm('¿Eliminar este control?');">

                            Eliminar
                        </button>

                    </form>

                </td>

            </tr>
        }

    </tbody>

</table>