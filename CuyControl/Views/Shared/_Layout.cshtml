<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CuyControl</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                background-color: #f4f6f9;
            }

            .sidebar {
                min-height: 100vh;
                background: #1f2937;
            }

                .sidebar a {
                    color: #d1d5db;
                    text-decoration: none;
                    display: block;
                    padding: 12px 20px;
                }

                    .sidebar a:hover {
                        background: #374151;
                        color: #fff;
                    }

            .content {
                padding: 25px;
            }

            .topbar {
                background: #fff;
                border-bottom: 1px solid #e5e7eb;
                padding: 15px 25px;
            }
    </style>
</head>

<body>
    <div class="d-flex">
            <aside class="sidebar col-md-2 p-0">
            <h4 class="text-white text-center py-4">CuyControl</h4>

            <a asp-controller="Home" asp-action="Index">Dashboard</a>
            <a asp-controller="Cuy" asp-action="Index">Inventario de Cuyes</a>
            <a asp-controller="Galpon" asp-action="Index">Galpones</a>
            <a asp-controller="Jaula" asp-action="Index">Jaulas</a>
            <a asp-controller="InventarioAlimento" asp-action="Index">Inventario de Alimentos</a>
            <a asp-controller="MovimientoAlimento" asp-action="Index">Movimientos de Alimento</a>
            <a asp-controller="Sanidad" asp-action="Index">Sanidad</a>
            <a asp-controller="Reproduccion" asp-action="Index">Reproducción</a>
            <a asp-controller="Venta" asp-action="Index">Ventas</a>
            <a asp-controller="Reporte" asp-action="Index">Reportes</a>
        </aside>

        <div class="flex-grow-1">
            <header class="topbar d-flex justify-content-between align-items-center">
                <strong>Sistema de Inventario y Manejo de Cuyes</strong>
                <div>
                    @if (User?.Identity?.IsAuthenticated ?? false)
                    {
                        <span class="me-3">Hola, @User.Identity.Name</span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-outline-secondary">Cerrar sesión</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-primary">Iniciar sesión</a>
                    }
                </div>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
