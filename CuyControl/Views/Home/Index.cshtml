@using CuyControl.Web.ViewModels
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">
    <h1 class="mb-4">Dashboard</h1>

    <div class="row">
        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Total de Cuyes</h5>
                    <h2>@Model.TotalCuyes</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white">
                <div class="card-body">
                    <h5 class="card-title">Cuyes Activos</h5>
                    <h2>@Model.CuyesActivos</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-white">
                <div class="card-body">
                    <h5 class="card-title">Cuyes Enfermos</h5>
                    <h2>@Model.CuyesEnfermos</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-danger text-white">
                <div class="card-body">
                    <h5 class="card-title">Cuyes Muertos</h5>
                    <h2>@Model.CuyesMuertos</h2>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-4">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Ventas</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">
                        <strong>Total Ventas:</strong> @Model.TotalVentas.ToString("C")<br />
                        <strong>Este Mes:</strong> @Model.VentasEsteMes.ToString("C")<br />
                        <strong>Registros:</strong> @Model.RegistrosEsteMes
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Información General</h5>
                </div>
                <div class="card-body">
                    <p class="card-text">
                        <strong>Galpones:</strong> @Model.TotalGalpones<br />
                        <strong>Inventario Alimento:</strong> @Model.InventarioAlimento kg<br />
                        <strong>Ocupación Jaulas:</strong> @Model.PorcentajeOcupacionJaulas%
                    </p>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-md-12">
            <div class="card">
                <div class="card-header bg-light">
                    <h5 class="card-title mb-0">Acciones Rápidas</h5>
                </div>
                <div class="card-body">
                    <a href="@Url.Action("Create", "Cuy")" class="btn btn-primary me-2">
                        <i class="fas fa-plus"></i> Nuevo Cuy
                    </a>
                    <a href="@Url.Action("Create", "Venta")" class="btn btn-success me-2">
                        <i class="fas fa-shopping-cart"></i> Nueva Venta
                    </a>
                    <a href="@Url.Action("Index", "Reporte")" class="btn btn-info">
                        <i class="fas fa-chart-bar"></i> Ver Reportes
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="row mt-3">
        <div class="col-md-12 text-muted">
            <small>Última actualización: @Model.UltimaActualizacion.ToString("dd/MM/yyyy HH:mm")</small>
        </div>
    </div>
</div>
<div class="row mt-4">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Cuyes por Sexo</div>
            <div class="card-body">
                <canvas id="sexoChart"></canvas>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card">
            <div class="card-header">Ventas por Mes</div>
            <div class="card-body">
                <canvas id="ventasChart"></canvas>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
    const sexoChart = new Chart(document.getElementById('sexoChart'), {
    type: 'doughnut',
    data: {
    labels: ['Machos', 'Hembras'],
    datasets: [{
    data: [@Model.TotalMachos, @Model.TotalHembras]
    }]
    }
    });

    const ventasChart = new Chart(document.getElementById('ventasChart'), {
    type: 'bar',
    data: {
    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MesesVentas)),
    datasets: [{
    label: 'Ventas S/',
    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MontosVentas))
    }]
    }
    });
</script>