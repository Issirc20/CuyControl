@using CuyControl.Web.ViewModels
@model DashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid mt-4">

    <h1 class="mb-4">Dashboard</h1>

    <!-- TARJETAS PRINCIPALES -->
    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card bg-primary text-white shadow">
                <div class="card-body">
                    <h5>Total de Cuyes</h5>
                    <h2>@Model.TotalCuyes</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <h5>Cuyes Activos</h5>
                    <h2>@Model.CuyesActivos</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-warning text-white shadow">
                <div class="card-body">
                    <h5>Cuyes Enfermos</h5>
                    <h2>@Model.CuyesEnfermos</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-danger text-white shadow">
                <div class="card-body">
                    <h5>Cuyes Muertos</h5>
                    <h2>@Model.CuyesMuertos</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- TARJETAS SECUNDARIAS -->
    <div class="row">

        <div class="col-md-3 mb-4">
            <div class="card bg-info text-white shadow">
                <div class="card-body">
                    <h5>Total Jaulas</h5>
                    <h2>@Model.TotalJaulas</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-secondary text-white shadow">
                <div class="card-body">
                    <h5>Enfermedades</h5>
                    <h2>@Model.TotalEnfermedades</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-dark text-white shadow">
                <div class="card-body">
                    <h5>Stock Bajo</h5>
                    <h2>@Model.StockBajo</h2>
                </div>
            </div>
        </div>

        <div class="col-md-3 mb-4">
            <div class="card bg-success text-white shadow">
                <div class="card-body">
                    <h5>Peso Promedio</h5>
                    <h2>@Model.PesoPromedioCuyes.ToString("0.00")</h2>
                </div>
            </div>
        </div>

    </div>

    <!-- RESUMEN INVENTARIO DE CUYES -->
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Resumen del Inventario de Cuyes</h5>
                </div>

                <div class="card-body">
                    <div class="row text-center">

                        <div class="col-md-2 mb-3">
                            <div class="border rounded p-3 bg-light">
                                <h6>Disponibles</h6>
                                <h3>@Model.CuyesDisponibles</h3>
                            </div>
                        </div>

                        <div class="col-md-2 mb-3">
                            <div class="border rounded p-3">
                                <h6>Crías</h6>
                                <h3>@Model.Crias</h3>
                            </div>
                        </div>

                        <div class="col-md-2 mb-3">
                            <div class="border rounded p-3">
                                <h6>Recrías</h6>
                                <h3>@Model.Recrias</h3>
                            </div>
                        </div>

                        <div class="col-md-2 mb-3">
                            <div class="border rounded p-3">
                                <h6>Reproductores</h6>
                                <h3>@Model.Reproductores</h3>
                            </div>
                        </div>

                        <div class="col-md-2 mb-3">
                            <div class="border rounded p-3">
                                <h6>Gestantes</h6>
                                <h3>@Model.Gestantes</h3>
                            </div>
                        </div>

                        <div class="col-md-2 mb-3">
                            <div class="border rounded p-3">
                                <h6>Para Venta</h6>
                                <h3>@Model.ParaVenta</h3>
                            </div>
                        </div>

                    </div>

                    <div class="alert alert-info mb-0">
                        Los cuyes vendidos y muertos no se consideran disponibles.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- INFORMACIÓN GENERAL -->
    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Ventas</h5>
                </div>

                <div class="card-body">
                    <p>
                        <strong>Total Ventas:</strong>
                        @Model.TotalVentas.ToString("C")
                    </p>

                    <p>
                        <strong>Ventas Este Mes:</strong>
                        @Model.VentasEsteMes.ToString("C")
                    </p>

                    <p>
                        <strong>Registros Este Mes:</strong>
                        @Model.RegistrosEsteMes
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Información General</h5>
                </div>

                <div class="card-body">
                    <p>
                        <strong>Galpones:</strong>
                        @Model.TotalGalpones
                    </p>

                    <p>
                        <strong>Inventario de Alimento:</strong>
                        @Model.InventarioAlimento kg
                    </p>

                    <p>
                        <strong>Ocupación Jaulas:</strong>
                        @Model.PorcentajeOcupacionJaulas %
                    </p>
                </div>
            </div>
        </div>

    </div>

    <!-- GRÁFICOS -->
    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header">
                    Cuyes por Sexo
                </div>

                <div class="card-body">
                    <canvas id="sexoChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header">
                    Ventas por Mes
                </div>

                <div class="card-body">
                    <canvas id="ventasChart"></canvas>
                </div>
            </div>
        </div>

    </div>

    <!-- NUEVOS GRÁFICOS -->
    <div class="row">

        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header">
                    Estado de Cuyes
                </div>

                <div class="card-body">
                    <canvas id="estadoChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow">
                <div class="card-header">
                    Inventario de Alimentos
                </div>

                <div class="card-body">
                    <canvas id="alimentoChart"></canvas>
                </div>
            </div>
        </div>

    </div>

    <!-- ACCIONES -->
    <div class="row">

        <div class="col-md-12 mb-4">

            <div class="card shadow">

                <div class="card-header bg-light">
                    <h5 class="mb-0">Acciones Rápidas</h5>
                </div>

                <div class="card-body">

                    <a asp-controller="Cuy"
                       asp-action="Create"
                       class="btn btn-primary me-2">
                        Nuevo Cuy
                    </a>

                    <a asp-controller="Venta"
                       asp-action="Create"
                       class="btn btn-success me-2">
                        Nueva Venta
                    </a>

                    <a asp-controller="Reporte"
                       asp-action="Index"
                       class="btn btn-info">
                        Ver Reportes
                    </a>

                </div>

            </div>

        </div>

    </div>

    <!-- FOOTER -->
    <div class="row">

        <div class="col-md-12 text-muted">
            <small>
                Última actualización:
                @Model.UltimaActualizacion.ToString("dd/MM/yyyy HH:mm")
            </small>
        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>

    // SEXO
    const sexoChart = new Chart(document.getElementById('sexoChart'), {
    type: 'doughnut',
    data: {
    labels: ['Machos', 'Hembras'],
    datasets: [{
    data: [@Model.TotalMachos, @Model.TotalHembras]
    }]
    }
    });

    // VENTAS
    const ventasChart = new Chart(document.getElementById('ventasChart'), {
    type: 'bar',
    data: {
    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MesesVentas)),
    datasets: [{
    label: 'Ventas S/',
    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MontosVentas))
    }]
    }
    });

    // ESTADOS
    const estadoChart = new Chart(document.getElementById('estadoChart'), {
    type: 'pie',
    data: {
    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EstadosCuyesLabels)),
    datasets: [{
    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.EstadosCuyesData))
    }]
    }
    });

    // ALIMENTOS
    const alimentoChart = new Chart(document.getElementById('alimentoChart'), {
    type: 'bar',
    data: {
    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlimentosLabels)),
    datasets: [{
    label: 'Stock',
    data: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AlimentosData))
    }]
    }
    });

</script>