@model CuyControl.Web.ViewModels.VentaViewModel

<h2>Editar Venta</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label class="form-label">Cuy</label>
        <select asp-for="CuyId" asp-items="ViewBag.Cuyes" class="form-select">
            <option value="">Seleccione</option>
        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha Venta</label>
        <input asp-for="FechaVenta" type="date" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Precio Unitario</label>
        <input asp-for="PrecioUnitario" type="number" step="0.01" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Cantidad</label>
        <input asp-for="Cantidad" type="number" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Comprador</label>
        <input asp-for="NombreComprador" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Contacto</label>
        <input asp-for="ContactoComprador" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Método Pago</label>
        <input asp-for="MetodoPago" class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Observaciones</label>
        <textarea asp-for="Observaciones" class="form-control"></textarea>
    </div>

    <button type="submit" class="btn btn-success">Actualizar</button>
    <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
</form>