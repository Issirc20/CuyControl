@model CuyControl.Web.ViewModels.VentaViewModel

@{
    ViewData["Title"] = "Nueva Venta";
}

<h2>Registrar Venta</h2>

<form asp-action="Create" method="post">

    <div class="mb-3">
        <label class="form-label">Cuy</label>

        <select asp-for="CuyId"
                asp-items="ViewBag.Cuyes"
                class="form-select">

            <option value="">Seleccione</option>

        </select>

        <span asp-validation-for="CuyId"
              class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label class="form-label">Fecha Venta</label>

        <input asp-for="FechaVenta"
               type="date"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Precio Unitario</label>

        <input asp-for="PrecioUnitario"
               type="number"
               step="0.01"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Cantidad</label>

        <input asp-for="Cantidad"
               type="number"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Comprador</label>

        <input asp-for="NombreComprador"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Contacto</label>

        <input asp-for="ContactoComprador"
               class="form-control" />
    </div>

    <div class="mb-3">
        <label class="form-label">Método Pago</label>

        <select asp-for="MetodoPago"
                class="form-select">

            <option>Efectivo</option>
            <option>Yape</option>
            <option>Plin</option>
            <option>Transferencia</option>

        </select>
    </div>

    <div class="mb-3">
        <label class="form-label">Observaciones</label>

        <textarea asp-for="Observaciones"
                  class="form-control"></textarea>
    </div>

    <button type="submit"
            class="btn btn-success">

        Guardar Venta
    </button>

    <a asp-action="Index"
       class="btn btn-secondary">

        Cancelar
    </a>

</form>
